# MacroPro environment configuration.
# Copy this file to `.env` and adjust as needed: `cp .env.example .env`
# The `.env` file is gitignored — keep local secrets there.

# --- Disable individual restaurant scrapers ---
# Set any of these to `true` to skip that scraper entirely (it contributes
# no menu items). Accepts: true / 1 / yes / on (anything else means enabled).
DISABLE_POPEYES=false
DISABLE_KFC=false
DISABLE_WENDYS=false
DISABLE_MCDONALDS=false
DISABLE_SUBWAY=false
DISABLE_TACOBELL=false
DISABLE_WAGAMAMA=false
DISABLE_DOMINOS=false
DISABLE_NANDOS=false
DISABLE_ITSU=false
DISABLE_YOSUSHI=false

# --- Default category exclusions (CLI only) ---
# Comma-separated category names to leave out of every optimization by
# default (case-insensitive), e.g. Drinks aren't a meal item for macro
# fitting. Overridden (not merged) by -x/--exclude-category. The web app has
# no default — it starts unfiltered and remembers your choice in the browser.
EXCLUDE_CATEGORIES=Drinks

# --- MyFitnessPal credentials (optional) ---
# Used to auto-fill target macros and push results. Leave blank to log in
# interactively in the browser instead.
MFP_EMAIL=
MFP_PASSWORD=
