{
  "manifest_version": 3,
  "name": "MacroPro MyFitnessPal Companion",
  "version": "0.1.0",
  "description": "Pull your remaining macros and log meals from MacroPro using your existing MyFitnessPal session. No password is ever stored.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["scripting", "tabs"],
  "host_permissions": ["https://*.myfitnesspal.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "https://macropro.sefijant.workers.dev/*",
        "https://macropro.food/*",
        "https://*.macropro.food/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "MacroPro MyFitnessPal Companion",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
