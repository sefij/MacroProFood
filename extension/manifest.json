{
  "manifest_version": 3,
  "name": "MacPro MyFitnessPal Companion",
  "version": "0.1.0",
  "description": "Pull your remaining macros and log meals from MacroPro using your existing MyFitnessPal session. No password is ever stored.",
  "permissions": ["scripting", "tabs"],
  "host_permissions": ["https://*.myfitnesspal.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "https://*.pages.dev/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "MacPro MyFitnessPal Companion"
  }
}
