{
  "name": "macropro",
  "version": "1.0.0",
  "description": "Scrape UK fast-food nutrition data and find meal combinations matching your target macros, with MyFitnessPal integration.",
  "main": "dist/main.js",
  "author": "Sefi Jantzis",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.11.0",
    "chalk": "^5.6.0",
    "cheerio": "^1.1.2",
    "commander": "^14.0.0",
    "lodash": "^4.17.21",
    "pdfjs-dist": "^5.4.530",
    "playwright": "^1.57.0",
    "typescript": "^7.0.2"
  },
  "scripts": {
    "start": "yarn run build && node dist/main.js",
    "build": "tsc",
    "build:data": "tsc && node dist/tools/build-web-data.js",
    "build:data:fresh": "tsc && node dist/tools/build-web-data.js --no-cache"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.21",
    "@types/node": "^25.0.3"
  }
}


